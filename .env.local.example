# Local development environment variables
# Copy this file to .env.local and adjust as needed

# PostgreSQL connection string for local development
# Use this when running the database via docker-compose
DATABASE_URL=postgres://postgres:postgres@localhost:5432/raumreservierung

# For Neon serverless driver to work with local PostgreSQL,
# you may need to use the pooled connection string format:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/raumreservierung?sslmode=disable
